# 环境配置
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/restaurant_finance?schema=public"
JWT_ACCESS_SECRET="your-access-secret-change-in-production"
JWT_REFRESH_SECRET="your-refresh-secret-change-in-production"
JWT_ACCESS_EXPIRES="2h"
JWT_REFRESH_EXPIRES="30d"

# Redis
REDIS_URL="redis://localhost:6379"

# MinIO (文件存储)
MINIO_ENDPOINT="localhost"
MINIO_PORT=9000
MINIO_ACCESS_KEY="minioadmin"
MINIO_SECRET_KEY="minioadmin"
MINIO_BUCKET="restaurant-finance"
MINIO_USE_SSL=false

# AI 服务地址
FUNASR_SERVICE_URL="http://localhost:8100"
PADDLEOCR_SERVICE_URL="http://localhost:8200"
OLLAMA_SERVICE_URL="http://localhost:11434"

# 服务端口
PORT=8080

# Puppeteer (简报生成)
PUPPETEER_EXECUTABLE_PATH=""
