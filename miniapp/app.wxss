/* 全局变量 */
page {
  --color-primary: #D4A574;
  --color-primary-dark: #B8895E;
  --color-bg: #f5f5f5;
  --color-white: #ffffff;
  --color-text: #333333;
  --color-text-secondary: #999999;
  --color-success: #52c41a;
  --color-warning: #faad14;
  --color-danger: #ff4d4f;
  --radius-sm: 8rpx;
  --radius-md: 12rpx;
  --radius-lg: 16rpx;
  --shadow-sm: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
  --shadow-md: 0 4rpx 16rpx rgba(0, 0, 0, 0.1);

  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
  font-size: 28rpx;
  color: var(--color-text);
  background-color: var(--color-bg);
}

/* 通用按钮 */
.btn-primary {
  background-color: var(--color-primary);
  color: #fff;
  border: none;
  border-radius: var(--radius-sm);
  padding: 20rpx 40rpx;
  font-size: 30rpx;
}

.btn-primary:active {
  background-color: var(--color-primary-dark);
}

/* 卡片容器 */
.card {
  background: var(--color-white);
  border-radius: var(--radius-md);
  padding: 24rpx;
  margin: 16rpx 24rpx;
  box-shadow: var(--shadow-sm);
}

/* 输入框 */
.input-group {
  margin-bottom: 24rpx;
}

.input-label {
  display: block;
  font-size: 26rpx;
  color: var(--color-text);
  margin-bottom: 8rpx;
}

.input-field {
  width: 100%;
  height: 80rpx;
  background: var(--color-bg);
  border-radius: var(--radius-sm);
  padding: 0 20rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

/* Flex 布局 */
.flex-row {
  display: flex;
  flex-direction: row;
  align-items: center;
}

.flex-between {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.flex-wrap {
  display: flex;
  flex-wrap: wrap;
}
