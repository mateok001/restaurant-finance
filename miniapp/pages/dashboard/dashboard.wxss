.dashboard {
  padding-bottom: 40rpx;
}

/* 欢迎栏 */
.welcome-bar {
  background: linear-gradient(135deg, #D4A574, #B8895E);
  padding: 40rpx 32rpx 36rpx;
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
}

.welcome-greeting {
  display: block;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-bottom: 4rpx;
}

.welcome-name {
  font-size: 36rpx;
  font-weight: 700;
  color: #fff;
}

.welcome-date {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}

/* 今日收入主卡片 */
.kpi-main-card {
  margin: -20rpx 24rpx 16rpx;
  background: #fff;
  border-radius: var(--radius-lg);
  padding: 32rpx;
  box-shadow: var(--shadow-md);
  text-align: center;
}

.kpi-main-label {
  font-size: 26rpx;
  color: var(--color-text-secondary);
}

.kpi-main-amount {
  font-size: 56rpx;
  font-weight: 700;
  color: var(--color-primary);
  margin: 12rpx 0;
}

.kpi-main-hint {
  font-size: 22rpx;
  color: #ccc;
}

/* KPI 行 */
.kpi-row {
  display: flex;
  margin: 0 24rpx 16rpx;
  gap: 16rpx;
}

.kpi-item {
  flex: 1;
  background: #fff;
  border-radius: var(--radius-md);
  padding: 24rpx 16rpx;
  text-align: center;
  box-shadow: var(--shadow-sm);
}

.kpi-item-label {
  font-size: 22rpx;
  color: var(--color-text-secondary);
  margin-bottom: 8rpx;
}

.kpi-item-amount {
  font-size: 28rpx;
  font-weight: 600;
}

.success { color: var(--color-success); }
.warning { color: var(--color-warning); }
.danger { color: var(--color-danger); }

/* 净利润 */
.profit-card {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin: 0 24rpx 24rpx;
  background: #fff;
  border-radius: var(--radius-md);
  padding: 24rpx;
  box-shadow: var(--shadow-sm);
}

.profit-label {
  font-size: 28rpx;
  color: var(--color-text);
}

.profit-amount {
  font-size: 32rpx;
  font-weight: 700;
}

/* 快捷入口 */
.quick-actions {
  display: flex;
  margin: 0 24rpx 24rpx;
  gap: 16rpx;
}

.action-item {
  flex: 1;
  background: #fff;
  border-radius: var(--radius-md);
  padding: 28rpx 16rpx;
  text-align: center;
  box-shadow: var(--shadow-sm);
  transition: transform 0.15s;
}

.action-item:active {
  transform: scale(0.96);
}

.action-icon {
  font-size: 56rpx;
  margin-bottom: 8rpx;
}

.action-text {
  font-size: 26rpx;
  color: var(--color-text);
}

/* 最近记录 */
.recent-section {
  margin: 0 24rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  margin-bottom: 16rpx;
}

.recent-item {
  background: #fff;
  border-radius: var(--radius-sm);
  padding: 24rpx;
  margin-bottom: 8rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  box-shadow: var(--shadow-sm);
}

.recent-title {
  font-size: 28rpx;
  color: var(--color-text);
  display: block;
}

.recent-date {
  font-size: 22rpx;
  color: #bbb;
  margin-top: 4rpx;
  display: block;
}

.recent-amount {
  font-size: 28rpx;
  font-weight: 600;
}
