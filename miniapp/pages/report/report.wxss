.report-page {
  padding-bottom: 40rpx;
}

/* 时间段切换 */
.period-bar {
  display: flex;
  background: #fff;
  padding: 8rpx 24rpx;
  gap: 12rpx;
}

.period-item {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  font-size: 26rpx;
  color: #999;
  border-radius: 24rpx;
  background: #f5f5f5;
}

.period-item.active {
  background: var(--color-primary);
  color: #fff;
}

/* 自定义日期 */
.date-range {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 24rpx;
  gap: 16rpx;
}

.date-picker {
  padding: 16rpx 24rpx;
  background: #fff;
  border-radius: var(--radius-sm);
  font-size: 26rpx;
  color: var(--color-primary);
  box-shadow: var(--shadow-sm);
}

.date-separator {
  font-size: 24rpx;
  color: #ccc;
}

/* KPI 网格 */
.kpi-grid {
  display: flex;
  flex-wrap: wrap;
  margin: 16rpx 24rpx;
  gap: 16rpx;
}

.kpi-card {
  width: calc(50% - 8rpx);
  background: #fff;
  border-radius: var(--radius-md);
  padding: 24rpx;
  box-shadow: var(--shadow-sm);
  box-sizing: border-box;
}

.kpi-label {
  display: block;
  font-size: 24rpx;
  color: var(--color-text-secondary);
  margin-bottom: 8rpx;
}

.kpi-value {
  font-size: 34rpx;
  font-weight: 700;
}

.success { color: var(--color-success); }
.warning { color: var(--color-warning); }
.danger { color: var(--color-danger); }

/* 图表 */
.chart-section {
  margin: 24rpx;
  background: #fff;
  border-radius: var(--radius-md);
  padding: 24rpx;
  box-shadow: var(--shadow-sm);
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  margin-bottom: 24rpx;
}

.bar-chart {
  display: flex;
  align-items: flex-end;
  gap: 8rpx;
  height: 280rpx;
  padding: 0 8rpx;
}

.bar-col {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-end;
  height: 100%;
}

.bar {
  width: 100%;
  max-width: 60rpx;
  border-radius: 4rpx 4rpx 0 0;
  min-height: 4rpx;
  transition: height 0.3s;
}

.bar-positive {
  background: linear-gradient(to top, #52c41a, #95de64);
}

.bar-negative {
  background: linear-gradient(to bottom, #ff4d4f, #ffa39e);
}

.bar-label {
  font-size: 18rpx;
  color: #bbb;
  margin-top: 8rpx;
  white-space: nowrap;
}

/* 空状态 */
.empty-hint {
  text-align: center;
  padding: 100rpx 0;
  color: #ccc;
  font-size: 28rpx;
}
